DROP DATABASE IF EXISTS defaultdb;
CREATE DATABASE defaultdb;
USE defaultdb;

-- ============================================================================
-- 2. FRESH TABLE ARCHITECTURE
-- ============================================================================
CREATE TABLE cities (
    id INT PRIMARY KEY,
    name VARCHAR(100), 
    description TEXT,
    tag1 VARCHAR(50), 
    tag2 VARCHAR(50), 
    tag3 VARCHAR(50)
);

CREATE TABLE places (
    id INT AUTO_INCREMENT PRIMARY KEY,
    city_id INT, 
    name VARCHAR(100), 
    category VARCHAR(50), 
    description TEXT, 
    image_file VARCHAR(100),
    FOREIGN KEY (city_id) REFERENCES cities(id)
);

CREATE TABLE accommodations (
    id INT AUTO_INCREMENT PRIMARY KEY,
    city_id INT, 
    name VARCHAR(100), 
    type VARCHAR(20), 
    budget_category VARCHAR(20), 
    price INT, 
    rating FLOAT, 
    image_file VARCHAR(100),
    FOREIGN KEY (city_id) REFERENCES cities(id)
);

